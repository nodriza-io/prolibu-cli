{
  "name": "minimal",
  "label": "Minimal Migration",
  "description": "Only products and contacts — fastest way to get core data into Prolibu",
  "config": {
    "entities": {
      "accounts": { "enabled": false },
      "products": { "enabled": true },
      "contacts": { "enabled": true },
      "opportunities": { "enabled": false },
      "leads": { "enabled": false }
    },
    "batchSize": 200
  },
  "pipeline": {
    "order": ["products", "contacts"]
  }
}
