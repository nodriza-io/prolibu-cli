{
  "pipeline": {
    "order": [
      "accounts",
      "products",
      "pricebooks",
      "pricebookentries",
      "contacts",
      "leads",
      "opportunities",
      "contracts",
      "cases",
      "tasks",
      "events",
      "campaigns",
      "notes"
    ],
    "flow": [
      { "name": "Base data", "entities": ["accounts", "products", "pricebooks", "pricebookentries"] },
      { "name": "People", "entities": ["contacts", "leads"] },
      { "name": "Deals", "entities": ["opportunities"] },
      { "name": "Operations", "entities": ["contracts", "cases"] },
      { "name": "Activities", "entities": ["tasks", "events", "campaigns", "notes"] }
    ],
    "batchSize": 200,
    "concurrency": 1,
    "onError": "skip"
  },
  "phases": [
    {
      "key": "discover",
      "label": "Discovery",
      "description": "Scan CRM and discover available objects and fields"
    },
    {
      "key": "review",
      "label": "Review & Configure",
      "description": "Review discovered objects, select entities and fields"
    },
    {
      "key": "migrate",
      "label": "Migration",
      "description": "Execute data migration from CRM to Prolibu"
    }
  ]
}